# =============================
# LOCAL DESKTOP DEFAULT
# =============================
# You may leave these unset for normal desktop development.
# Default client API: http://localhost:8000/api/v1
# Default socket:     http://localhost:8000

# =============================
# LOCAL MOBILE / LAN TEST
# =============================
# Replace 192.168.0.105 with your PC IPv4 from ipconfig.
# Do NOT use these values in production deploy settings.
NEXT_PUBLIC_API_URL=http://192.168.0.105:8000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://192.168.0.105:8000
NEXT_PUBLIC_LUDO_BACKEND_URL=http://192.168.0.105:8000

# =============================
# NGROK TEST, IF NEEDED
# =============================
# NEXT_PUBLIC_API_URL=https://your-ngrok-url.ngrok-free.app/api/v1
# NEXT_PUBLIC_SOCKET_URL=https://your-ngrok-url.ngrok-free.app
# NEXT_PUBLIC_LUDO_BACKEND_URL=https://your-ngrok-url.ngrok-free.app

# =============================
# PRODUCTION EXAMPLE
# =============================
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
# NEXT_PUBLIC_SOCKET_URL=https://api.yourdomain.com
# NEXT_PUBLIC_LUDO_BACKEND_URL=https://api.yourdomain.com
# API_PROXY_TARGET=https://api.yourdomain.com
